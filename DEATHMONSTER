const DISCORD_WEBHOOK = "https://discordapp.com/api/webhooks/1483557471292362893/pC3F3WudoNOO0WWAVfPAlVM_cJi_79mtER4icgaT5t0XI1WfDRNiJhb6jAI0XWJ84E6C";

// Sheets that should trigger the system
const TARGET_SHEETS = ["CustomerOrders", "PlayerPurchases"];

function onEdit(e) {
  const sheet = e.source.getActiveSheet();
  const sheetName = sheet.getName();

  // Only run on the two target sheets
  if (!TARGET_SHEETS.includes(sheetName)) return;

  const row = e.range.getRow();
  const col = e.range.getColumn();

  // Only run when Quantity column (C) is edited
  if (col === 3 && row > 1) {
    const orderNumberCell = sheet.getRange(row, 1);
    const itemCell = sheet.getRange(row, 2);
    const quantityCell = sheet.getRange(row, 3);
    const priceCell = sheet.getRange(row, 4);
    const totalCell = sheet.getRange(row, 5);

    const item = itemCell.getValue();
    const quantity = quantityCell.getValue();
    const price = priceCell.getValue();

    if (!quantity || !price) return;

    // Generate order number if missing
    if (!orderNumberCell.getValue()) {
      const orderNumber = sheetName.substring(0, 3).toUpperCase() + "-" + new Date().getTime();
      orderNumberCell.setValue(orderNumber);
    }

    const total = quantity * price;
    totalCell.setValue(total);

    // Send Discord notification
    sendDiscordNotification(
      sheetName,
      orderNumberCell.getValue(),
      item,
      quantity,
      price,
      total
    );
  }
}

function sendDiscordNotification(sheetName, orderNumber, item, quantity, price, total) {
  const payload = {
    content: `📦 **New Order Recorded in ${sheetName}**
**Order Number:** ${orderNumber}
**Item:** ${item}
**Quantity:** ${quantity}
**Price Each:** £${price}
**Total:** £${total}`
  };

  const params = {
    method: "post",
    contentType: "application/json",
    payload: JSON.stringify(payload)
  };

  UrlFetchApp.fetch(DISCORD_WEBHOOK, params);
}
